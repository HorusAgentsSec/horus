# Cabeceras de seguridad para producción. En dev/preview las pone vite.config.ts;
# un host estático debe ponerlas él mismo (el navegador ignora X-Frame-Options y
# CSP frame-ancestors si van por <meta>). Mantener en sintonía con vite.config.ts.
/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), camera=(), microphone=(), payment=()
  Cross-Origin-Opener-Policy: same-origin
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self'; connect-src 'self' https: wss:; frame-ancestors 'none'; base-uri 'self'; form-action 'self'

# ── Supabase ───────────────────────────────────────────────────────────────────
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── LLM Provider (OpenAI-compatible API) ──────────────────────────────────────
#
# Option A: OpenRouter (recommended — access to every model)
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=sk-or-...
LLM_DEFAULT_MODEL=anthropic/claude-opus-4-5
#
# Option B: Ollama (local models)
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_API_KEY=ollama
# LLM_DEFAULT_MODEL=llama3.1:70b
#
# Option C: Direct OpenAI
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=sk-...
# LLM_DEFAULT_MODEL=gpt-4o
#
# Per-agent model overrides (optional — all fall back to LLM_DEFAULT_MODEL)
# LLM_ANALYST_MODEL=anthropic/claude-opus-4-5
# LLM_THREAT_INTEL_MODEL=openai/gpt-4o
# LLM_VALIDATION_MODEL=anthropic/claude-opus-4-5   # the red/blue debate; benefits from a strong model
# LLM_REMEDIATION_MODEL=meta-llama/llama-3.1-70b-instruct
# LLM_RISK_MANAGER_MODEL=anthropic/claude-haiku-4-5
# LLM_REPORTER_MODEL=anthropic/claude-haiku-4-5

# ── Pipeline robustness ─────────────────────────────────────────────────────────
LLM_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=2
PIPELINE_MAX_CONCURRENCY=2   # max scans running at once; extras queue
SCAN_MAX_RETRIES=1           # auto-retry a failed *scheduled* scan this many times (self-healing)

# ── Data privacy ─────────────────────────────────────────────────────────────────
# Pseudonymize sensitive identifiers (hostnames, IPs, emails) in every prompt before it leaves the
# process for a cloud LLM, restoring them in the response. On by default (privacy by design). Turn
# off only if you run a fully local model or want maximum model fidelity.
REDACTION_ENABLED=true
# Master switch for the LLM agents. false = fully deterministic "no-cloud" mode: the whole pipeline
# runs with ZERO LLM calls (rule-based analyst, auto-only validation, no remediation drafting,
# templated report). The deterministic core (CVE correlation, SSVC, posture, Watchtower) is
# unaffected. For air-gapped / maximum-privacy deployments where no data may leave the perimeter.
LLM_ENABLED=true

# ── Community verdicts (cross-customer false-positive flywheel) ───────────────────
# Aggregate per-org verdict feedback across the fleet (anonymized; k-anonymity = min 3 distinct
# orgs enforced in the DB function) so a new org benefits from what everyone has learned. Daily job.
COMMUNITY_VERDICTS_ENABLED=true
COMMUNITY_VERDICTS_CRON=0 4 * * *

# ── Analyst team (parallel domain specialists) ───────────────────────────────────
# Route each raw finding to a domain specialist (web / network / TLS) and analyze in parallel for
# sharper, lower-latency results. Off → a single generalist analyst call.
ANALYST_TEAM_ENABLED=true

# ── Finding validation (red/blue adversarial debate) ─────────────────────────────
# Calibrates confidence and catches false positives. Obvious findings (KEV-active, info) are
# resolved deterministically for free; only ambiguous ones reach the debate, capped per scan.
VALIDATION_ENABLED=true
VALIDATION_MAX_DEBATES=15     # max LLM debates per scan (cost bound)

# ── App ────────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
SECRET_KEY=changeme

# ── Rate limiting (in-memory, per-process) ──────────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=120            # per-IP across all /api routes
RATE_LIMIT_SENSITIVE_PER_MINUTE=10  # per-IP for scan trigger + team invite
# Set true ONLY behind a trusted reverse proxy — otherwise X-Forwarded-For is spoofable.
TRUST_PROXY_HEADERS=false

# ── Watchtower (continuous exposure monitoring) ─────────────────────────────────
# Daily, after the KEV/EPSS sync, re-correlate each asset's software inventory against
# newly known-exploited CVEs (no re-scan) and alert on new exposure.
WATCHTOWER_ENABLED=true
WATCHTOWER_CRON=30 5 * * *        # 30 min after the CVE sync
WATCHTOWER_LOOKBACK_DAYS=3        # a CVE is "new" if it entered CISA KEV within N days
# EPSS-spike early warning: alert when an inventoried CVE's exploitation probability jumps
# day-over-day (often before it reaches KEV). Needs new score ≥ floor AND a rise ≥ delta.
WATCHTOWER_EPSS_SPIKE_ENABLED=true
WATCHTOWER_EPSS_FLOOR=0.5         # only alert when EPSS is at least this (≥50%)
WATCHTOWER_EPSS_SPIKE_DELTA=0.2   # and it rose by at least this since yesterday

# ── Posture timeline (executive risk trend) ─────────────────────────────────────
# Daily per-org risk snapshot for the posture chart (also taken after scans + watchtower).
POSTURE_SNAPSHOT_ENABLED=true
POSTURE_SNAPSHOT_CRON=0 6 * * *   # after the watchtower run
# Monthly board report: email the posture PDF to email integrations opted in
# (Integrations → email → "Board report"). Needs SMTP configured (see notifications above).
POSTURE_REPORT_ENABLED=true
POSTURE_REPORT_CRON=0 7 1 * *     # 07:00 on the 1st of each month
POSTURE_REPORT_DAYS=90            # trend window covered by the emailed report

# ── Optional integrations ──────────────────────────────────────────────────────
SHODAN_API_KEY=

# ── Frontend (Vite) ────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=

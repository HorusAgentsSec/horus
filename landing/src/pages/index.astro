</style>

<script>
(function () {
  var reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (reduce || !('IntersectionObserver' in window)) return;

  var io = new IntersectionObserver(function (entries) {
    entries.forEach(function (e) {
      if (!e.isIntersecting) return;
      var t = e.target;
      t.classList.add('in');
      if (t.classList.contains('terminal')) typeTerminal(t);
      if (t.dataset.count) countUp(t);
      io.unobserve(t);
    });
  }, { threshold: 0.18, rootMargin: '0px 0px -6% 0px' });

  function mark(el) { el.classList.add('reveal'); io.observe(el); }

  ['.threat-stat', '.product-mock', '.debate', '.phish', '.terminal', '.feature-copy', '.trust'].forEach(function (sel) {
    document.querySelectorAll(sel).forEach(mark);
  });

  function staggerKids(container, step) {
    Array.prototype.forEach.call(container.children, function (ch, i) {
      ch.style.transitionDelay = (i * (step || 80)) + 'ms';
      mark(ch);
    });
  }
  ['.hero > .container', '.callout-inner', '.prob-grid', '.steps', '.price-grid', '.pipeline-agents'].forEach(function (sel) {
    document.querySelectorAll(sel).forEach(function (c) { staggerKids(c); });
  });
  document.querySelectorAll('.slabel').forEach(function (sl) {
    if (sl.parentElement) staggerKids(sl.parentElement, 90);
  });

  document.querySelectorAll('.threat-stat-num, .phish-val').forEach(function (el) {
    el.dataset.count = el.textContent.trim();
    io.observe(el);
  });

  function countUp(el) {
    var raw = el.dataset.count;
    var num = parseFloat(raw.replace(/[^0-9.]/g, ''));
    if (isNaN(num)) return;
    var hasComma = /,/.test(raw);
    var prefix = (raw.match(/^[^0-9.,]+/) || [''])[0];
    var suffix = (raw.match(/[^0-9.,]+$/) || [''])[0];
    var dur = 1100, start = null;
    function fmt(n) {
      var s = Math.round(n).toString();
      if (hasComma) s = s.replace(/\B(?=(\d{3})+(?!\d))/g, ',');
      return prefix + s + suffix;
    }
    function tick(now) {
      if (start === null) start = now;
      var p = Math.min(1, (now - start) / dur);
      el.textContent = fmt(num * (1 - Math.pow(1 - p, 3)));
      if (p < 1) requestAnimationFrame(tick);
    }
    el.textContent = fmt(0);
    requestAnimationFrame(tick);
  }

  function typeTerminal(t) {
    Array.prototype.forEach.call(t.querySelectorAll('.tbody > *'), function (ln, i) {
      ln.style.animationDelay = (i * 130) + 'ms';
    });
  }
})();
</script>

  .trust-row { display: flex; align-items: center; gap: 26px; flex-wrap: wrap; justify-content: center; }
  .trust-row span { font-family: 'JetBrains Mono', monospace; font-size: 12px; letter-spacing: .02em; color: var(--muted); opacity: .65; transition: opacity .2s ease, color .2s ease; }

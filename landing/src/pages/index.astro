  if (!svg) return;

  var STEPS = [
    { nodes: ['n-recon'],              edges: [],              color: '#6B9FEF', msg: '→ Recon: scanning 147 assets (nmap + nuclei)…', dur: 950 },
    { nodes: ['n-analyst'],            edges: ['e1'],          color: '#27C2B6', msg: '→ Analyst: enriching 23 findings, scoring relevance…', dur: 800 },
    { nodes: ['n-threat'],             edges: ['e2'],          color: '#E8B94A', msg: '→ Threat Intel: 4 CVE matched · 1 KEV-active · EPSS 0.91', dur: 900 },
    { nodes: ['n-red', 'n-blue'],      edges: ['e3', 'e4'],   color: '#E05252', msg: '⚔ Red/Blue debate: 4 findings in scope', dur: 700 },
    { nodes: [],                        edges: ['e5', 'e6'],   color: null,       msg: '⚔ Debate round 2: Red escalates CVE-2024-3400…', dur: 750 },
    { nodes: [],                        edges: ['e6', 'e5'],   color: null,       msg: '⚔ Blue counters: compensating control in WAF…', dur: 700 },
    { nodes: ['n-valid'],              edges: ['e7', 'e8'],    color: '#27C2B6', msg: '✓ Validation: 3 confirmed · 1 FP suppressed', dur: 850 },
    { nodes: ['n-risk'],               edges: ['e9'],          color: '#F59E0B', msg: '⚠ Risk Mgr: 1 ACT · 2 ATTEND · 0 TRACK (SSVC)', dur: 800 },
    { nodes: ['n-report'],             edges: ['e10'],         color: '#E8B94A', msg: '✓ Report ready · 3 critical findings · 5.8s elapsed', dur: 2800 },
  ];

  function setTicker(msg, color) {
    if (tickerMsg) tickerMsg.textContent = msg;
    if (tickerDot && color) tickerDot.style.background = color;
  }

  function firePacket(edgeId, color) {
    var path = document.getElementById(edgeId);
    if (!path) return;
    var litClass = color === '#E05252' ? 'ag-lit-r' : color === '#6B9FEF' ? 'ag-lit-b' : 'ag-lit';
    path.classList.add(litClass);

    var c = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
    c.setAttribute('r', '1.5');
    c.setAttribute('fill', color || '#E8B94A');
    c.style.filter = 'drop-shadow(0 0 2px ' + (color || '#E8B94A') + ')';

    var mo = document.createElementNS('http://www.w3.org/2000/svg', 'animateMotion');
    mo.setAttribute('dur', '0.55s');
    mo.setAttribute('fill', 'remove');
    var mp = document.createElementNS('http://www.w3.org/2000/svg', 'mpath');
    mp.setAttributeNS('http://www.w3.org/1999/xlink', 'xlink:href', '#' + edgeId);
    mo.appendChild(mp);
    c.appendChild(mo);
    svg.appendChild(c);

    setTimeout(function () {
      path.classList.remove('ag-lit', 'ag-lit-r', 'ag-lit-b');
      if (svg.contains(c)) svg.removeChild(c);
    }, 700);
  }

  function activateNode(id) {
    var el = document.getElementById(id);
    if (el) el.classList.add('ag-active');
  }

  function resetAll() {
    document.querySelectorAll('.ag-node').forEach(function (n) { n.classList.remove('ag-active'); });
    svg.querySelectorAll('circle').forEach(function (c) { svg.removeChild(c); });
  }

  var timer;
  function runStep(i) {
    var step = STEPS[i];
    if (!step) {
      setTicker('✓ Pipeline complete · next run in 24h', '#27C2B6');
      timer = setTimeout(function () {
        resetAll();
        setTicker('Waiting for pipeline trigger…', 'var(--teal)');
        timer = setTimeout(function () { runStep(0); }, 1000);
      }, 2500);
      return;
    }

    var col = step.color || (i % 2 === 0 ? '#E05252' : '#6B9FEF');
    setTicker(step.msg, col);

    step.edges.forEach(function (eid) { firePacket(eid, step.color); });

    if (step.nodes.length) {
      setTimeout(function () { step.nodes.forEach(activateNode); }, step.edges.length ? 560 : 0);
    }

    timer = setTimeout(function () { runStep(i + 1); }, step.dur);
  }

  var started = false;
  var sio = new IntersectionObserver(function (entries) {
    if (entries[0].isIntersecting && !started) {
      started = true;
      sio.disconnect();
      setTimeout(function () { runStep(0); }, 200);
    }
  }, { threshold: 0.5, rootMargin: '0px 0px -80px 0px' });
  var canvas = document.querySelector('.ag-canvas');
  if (canvas) sio.observe(canvas); else runStep(0);
})();
</script>

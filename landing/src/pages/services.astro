<script>
  const sections = ['defense','adversarial','intelligence','governance'];
  const links = document.querySelectorAll('.anchor-link');
  const observer = new IntersectionObserver(entries => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        links.forEach(l => l.classList.remove('active'));
        const active = document.querySelector(`.anchor-link[href="#${e.target.id}"]`);
        if (active) active.classList.add('active');
      }
    });
  }, { threshold: 0.2 });
  sections.forEach(id => { const el = document.getElementById(id); if (el) observer.observe(el); });
</script>

<script>
(function () {
  var reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (reduce || !('IntersectionObserver' in window)) return;

  var io = new IntersectionObserver(function (entries) {
    entries.forEach(function (e) {
      if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); }
    });
  }, { threshold: 0.15, rootMargin: '0px 0px -6% 0px' });

  function mark(el) { el.classList.add('reveal'); io.observe(el); }

  // Hero word reveal
  var ph = document.querySelector('.page-hero');
  if (ph) requestAnimationFrame(function () { ph.classList.add('hero-boot'); });

  document.querySelectorAll('.feat-grid').forEach(mark);

  function staggerKids(c, step, skipH1) {
    Array.prototype.forEach.call(c.children, function (ch, i) {
      if (skipH1 && ch.tagName === 'H1') return;
      ch.style.transitionDelay = (i * (step || 90)) + 'ms';
      mark(ch);
    });
  }

  // Hero: skip h1 (handled by hw spans)
  var heroC = document.querySelector('.page-hero > .container');
  if (heroC) staggerKids(heroC, 90, true);

  document.querySelectorAll('.cat-header, .bottom-cta > .container').forEach(function (c) {
    staggerKids(c);
  });
})();
</script>
